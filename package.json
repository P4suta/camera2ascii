{
	"name": "camera2ascii",
	"version": "1.0.0",
	"description": "Real-time webcam to ASCII art converter",
	"type": "module",
	"scripts": {
		"dev": "bun build ./src/main.ts --outdir ./dist --target browser --watch",
		"build": "bun build ./src/main.ts --outdir ./dist --target browser --minify",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"lint": "biome lint ./src",
		"format": "biome format --write ./src",
		"check": "biome check ./src && tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@happy-dom/global-registrator": "^20.8.9",
		"@stryker-mutator/core": "^9.6.1",
		"@types/bun": "^1.3.12",
		"fast-check": "^4.5.3",
		"happy-dom": "^20.8.9",
		"typescript": "^6.0.2"
	},
	"private": true
}
